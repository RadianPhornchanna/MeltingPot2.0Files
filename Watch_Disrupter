import numpy as np
from meltingpot import substrate
import pygame
import sys

def watch_game():
    env_name = 'commons_harvest__open'
    roles = ['default'] * 7
    env = substrate.build(env_name, roles=roles)

    pygame.init()
    screen_size = (800, 600)
    display = pygame.display.set_mode(screen_size)
    pygame.display.set_caption("Watching the Disruptor (Agent 5)")
    clock = pygame.time.Clock()

    num_actions = env.action_spec()[0].num_values
    timestep = env.reset()

    print("Watching... Press Ctrl+C in terminal or close window to stop.")

    running = True
    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

        # Generate actions for all 7 agents
        actions = []
        for i in range(7):
            if i == 5: # Agent 6 (index 5) is the Bully
                if np.random.random() < 0.20:
                    actions.append(num_actions - 1) # Zap
                else:
                    actions.append(np.random.randint(0, num_actions)) # Full movement
            else:
                actions.append(np.random.randint(0, min(4, num_actions))) # Limited movement

        timestep = env.step(actions)

        # FIX: Access the first agent's observation to get the world view
        rgb_scene = timestep.observation[0]['WORLD.RGB']

        # Render
        surface = pygame.surfarray.make_surface(rgb_scene.transpose(1, 0, 2))
        surface = pygame.transform.scale(surface, screen_size)
        display.blit(surface, (0, 0))
        pygame.display.flip()

        clock.tick(20) # Slightly slower so you can actually see the zaps

        if timestep.last():
            timestep = env.reset()

    env.close()
    pygame.quit()

if __name__ == "__main__":
    watch_game()

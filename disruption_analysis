import numpy as np
import pandas as pd
from meltingpot import substrate
import sys

def run_trial(trial_num):
    env_name = 'commons_harvest__open'
    roles = ['default'] * 7
    env = substrate.build(env_name, roles=roles)

    # Dynamically find the action limit (prevents the 'Index out of range' error)
    num_actions = env.action_spec()[0].num_values

    timestep = env.reset()
    total_rewards = np.zeros(7)

    for _ in range(1000):
        actions = []
        for i in range(7):
            if i == 5: # The Disruptor (Agent 6)
                # 20% chance to use the "Special" action (Zap beam)
                if np.random.random() < 0.20:
                    actions.append(num_actions - 1)
                else:
                    # Agent 6 can move in all 8 directions
                    actions.append(np.random.randint(0, num_actions))
            else:
                # Normal agents restricted to basic 4-way movement
                actions.append(np.random.randint(0, min(4, num_actions)))

        timestep = env.step(actions)
        total_rewards += timestep.reward

    env.close()

    # Save Results
    df = pd.DataFrame({'Agent': range(7), 'Score': total_rewards})
    df.to_csv(f'disrupted_trial_{trial_num}.csv', index=False)
    print(f"🔥 Disrupted Trial {trial_num} saved.")

if __name__ == "__main__":
    if len(sys.argv) > 1:
        run_trial(sys.argv[1])



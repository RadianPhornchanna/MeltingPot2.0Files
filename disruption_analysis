import pandas as pd
import matplotlib.pyplot as plt
import glob
import numpy as np

def analyze_disruption():
    # 1. Find all your disrupted CSV files
    disrupted_files = glob.glob("disrupted_*.csv")

    if not disrupted_files:
        print("No files found! Make sure they are named disrupted_1.csv, disrupted_2.csv, etc.")
        return

    print(f"Found {len(disrupted_files)} runs. Processing results...")

    # 2. Load Data
    all_runs = [pd.read_csv(f) for f in disrupted_files]
    combined = pd.concat(all_runs)

    # Calculate Mean and Standard Deviation for time-series
    mean_data = combined.groupby('step').mean().reset_index()
    std_data = combined.groupby('step').std().reset_index()

    # Calculate Average Final Scores for the Bar Chart
    final_steps = [run.iloc[-1] for run in all_runs]
    final_df = pd.DataFrame(final_steps)
    agent_cols = [f'agent_{i}_score' for i in range(7)]
    avg_final_scores = final_df[agent_cols].mean()
    sem_final_scores = final_df[agent_cols].sem() # Error bars for the bars

    # 3. Create the Visuals
    plt.figure(figsize=(18, 5))

    # --- Graph 1: Total Apples (Efficiency) ---
    plt.subplot(1, 3, 1)
    plt.plot(mean_data['step'], mean_data['total_apples'], color='red', label='Mean Total')
    plt.fill_between(mean_data['step'],
                     mean_data['total_apples'] - std_data['total_apples'],
                     mean_data['total_apples'] + std_data['total_apples'],
                     color='red', alpha=0.2)
    plt.title('Total Apples Collected')
    plt.xlabel('Steps')
    plt.grid(True, alpha=0.2)
    plt.legend()

    # --- Graph 2: Gini Index (Inequality) ---
    plt.subplot(1, 3, 2)
    plt.plot(mean_data['step'], mean_data['gini_index'], color='darkred')
    plt.title('Social Inequality (Gini Index)')
    plt.xlabel('Steps')
    plt.ylabel('Gini Coefficient')
    plt.grid(True, alpha=0.2)

    # --- Graph 3: Individual Agent Performance ---
    plt.subplot(1, 3, 3)
    colors = ['gray'] * 6 + ['red'] # Highlight Agent 6 in Red
    avg_final_scores.plot(kind='bar', yerr=sem_final_scores, color=colors, capsize=4)
    plt.title('Avg Final Score per Agent')
    plt.ylabel('Apples')
    plt.xticks(rotation=45)
    plt.grid(axis='y', alpha=0.3)

    plt.tight_layout()
    plt.savefig('disruption_analysis_report.png')
    print("📈 Triple-chart report saved as 'disruption_analysis_report.png'")
    plt.show()

if __name__ == "__main__":
    analyze_disruption()

import numpy as np
import pandas as pd
from meltingpot import substrate
import sys

def run_trial(trial_num):
    env_name = 'commons_harvest__open'
    roles = ['default'] * 7
    env = substrate.build(env_name, roles=roles)

    # Get max actions allowed by the map to prevent IndexError
    num_actions = env.action_spec()[0].num_values

    timestep = env.reset()
    total_rewards = np.zeros(7)

    # Run for 1000 steps
    for _ in range(1000):
        # All agents move randomly (0-3: Up, Down, Left, Right)
        actions = [np.random.randint(0, min(4, num_actions)) for _ in range(7)]
        timestep = env.step(actions)
        total_rewards += timestep.reward

    env.close()

    # Save Results
    df = pd.DataFrame({'Agent': range(7), 'Score': total_rewards})
    df.to_csv(f'baseline_trial_{trial_num}.csv', index=False)
    print(f"✅ Baseline Trial {trial_num} saved.")

if __name__ == "__main__":
    if len(sys.argv) > 1:
        run_trial(sys.argv[1])
